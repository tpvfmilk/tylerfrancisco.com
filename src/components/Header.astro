---
interface Props {
  current?: 'home' | 'writing' | 'about';
}
const { current } = Astro.props;
---

<div class="wrap">
  <header class="site">
    <a class="wordmark" href="/">tyler francisco<span class="dot">.</span></a>
    <nav class="site" aria-label="Primary">
      <a href="/" aria-current={current === 'home' ? 'page' : undefined}>Home</a>
      <a href="/writing/" aria-current={current === 'writing' ? 'page' : undefined}>Writing</a>
      <a href="/about/" aria-current={current === 'about' ? 'page' : undefined}>About</a>
    </nav>
  </header>
</div>
