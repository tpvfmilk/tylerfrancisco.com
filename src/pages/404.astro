---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import { SITE } from '../lib/site';
---

<Base title={`404 — ${SITE.title}`} description="Page not found.">
  <Header />

  <div class="wrap">
    <div class="lost">
      <span class="thumb art" aria-hidden="true">
        <svg viewBox="0 0 320 240" preserveAspectRatio="xMidYMid slice">
          <rect width="320" height="240" fill="var(--coral)"/>
          <g fill="none" stroke="var(--ink)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M96 150 C96 128 128 126 150 126 L214 126 C236 126 242 112 240 100"/>
            <path d="M240 100 C238 86 224 84 216 92 C210 98 214 108 222 108 L246 108"/>
            <path d="M108 150 V182 M132 150 V182 M198 150 V182 M222 150 V182"/>
            <path d="M228 96 C222 108 230 118 236 116"/>
          </g>
          <circle cx="230" cy="98" r="3.4" fill="var(--ink)"/>
        </svg>
      </span>
      <p class="code">404<span class="dot">.</span></p>
      <h1>This page wandered off.</h1>
      <p class="line">Probably following Soondae — dachshunds have zero respect for information architecture.</p>
      <div class="acts">
        <a class="btn" href="/">Back home</a>
        <a class="alt" href="/writing/">Read the writing instead ›</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .lost { max-width: 560px; margin: 0 auto; padding: clamp(24px, 6vw, 72px) 0 110px; text-align: center; }
  .art { aspect-ratio: 4 / 3; max-width: 340px; margin: 0 auto 34px; border-radius: 14px; }
  .code { font-size: clamp(56px, 12vw, 110px); font-weight: 800; letter-spacing: -0.045em; line-height: 0.9; margin: 0 0 8px; }
  .code .dot { color: var(--accent); }
  h1 { font-size: clamp(22px, 3.4vw, 30px); font-weight: 700; letter-spacing: -0.02em; margin: 0 0 10px; }
  .line { color: var(--muted); font-size: 16.5px; margin: 0 0 30px; }
  .acts { display: flex; align-items: center; justify-content: center; gap: 22px; flex-wrap: wrap; }
  .btn { display: inline-block; background: var(--accent); color: #fff; text-decoration: none;
    font-weight: 600; font-size: 15px; padding: 12px 22px; border-radius: 9px; transition: background .15s ease; }
  .btn:hover { background: var(--accent-hover); }
  .alt { color: var(--muted); text-decoration: none; font-size: 15px; font-weight: 500; transition: color .15s ease; }
  .alt:hover { color: var(--accent); }
</style>
