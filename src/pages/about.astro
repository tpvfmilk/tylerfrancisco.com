---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../lib/site';
---

<Base title={`About — ${SITE.title}`} description="Tyler Francisco — technical designer in Honolulu, de-facto AI & automation champion at an architecture firm, and keeper of a plain-text second brain.">
  <Header current="about" />

  <div class="wrap">
    <section class="about">
      <div class="about-grid">
        <div>
          <p class="eyebrow">About</p>
          <h1>I make architecture move faster with AI — and write down what actually works.</h1>
          <p>I'm Tyler, a technical designer at an architecture firm in Honolulu, where I ended up as the de-facto AI &amp; automation champion mostly by being the one who kept trying things. My day job is buildings; my obsession is the systems around them — the boring, reliable workflows that quietly remove the busywork so the design work gets more room.</p>
          <p class="soft">Off the clock I run a couple of small businesses, keep a second brain that lives entirely in plain text and Git, and get overruled daily by a dachshund named Soondae. This site is where I think out loud about all of it.</p>
          <ul class="currently">
            <li><span class="lab">Now</span> <span>Building an <b>AI daily brief</b> and an <b>AHL cost-trends database</b> that maintains itself.</span></li>
            <li><span class="lab">Ethos</span> <span>Lowest autonomy that works. <b>Eliminate → automate → delegate.</b> Boring is beautiful.</span></li>
            <li><span class="lab">Writing</span> <span>Field-tested <b>guides on AI in AEC</b>, plus shorter musings.</span></li>
          </ul>

          <div class="contact">
            <p class="eyebrow">Contact</p>
            <a class="mail" href={`mailto:${SITE.email}`}>{SITE.email}</a>
            <div class="socials">
              <a href="https://www.instagram.com/t_francisco" aria-label="Instagram" title="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="2.5" y="2.5" width="19" height="19" rx="5.5"/><circle cx="12" cy="12" r="4.4"/><circle cx="17.6" cy="6.4" r="1.1" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="https://github.com/tpvfmilk" aria-label="GitHub" title="GitHub">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.3.8-.6v-2c-3.2.7-3.9-1.5-3.9-1.5-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.3.8 1 .8 2.1v3.1c0 .3.2.7.8.6 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"/></svg>
              </a>
              <a href={`mailto:${SITE.email}`} aria-label="Email" title="Email">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><rect x="2.5" y="4.5" width="19" height="15" rx="2.5"/><path d="M3 6.5l9 6.2 9-6.2"/></svg>
              </a>
            </div>
          </div>
        </div>

        <div class="portrait">
          <img src="/images/about-portrait.webp" alt="Tyler Francisco seated on the steps of a columned building — aloha shirt, sunglasses" loading="lazy" decoding="async" width="880" height="1100" />
        </div>
      </div>
    </section>
  </div>

  <Footer />
</Base>

<style>
  .about { padding: clamp(24px, 5vw, 64px) 0 clamp(40px, 7vw, 96px); }
  .about-grid { display: grid; grid-template-columns: 1.35fr 1fr; gap: clamp(32px, 6vw, 80px); align-items: start; }
  .about h1 { font-size: clamp(28px, 4.4vw, 44px); font-weight: 750; letter-spacing: -0.03em; line-height: 1.1; margin: 0 0 22px; text-wrap: balance; }
  .about p { font-size: 17.5px; line-height: 1.7; color: var(--text); margin: 0 0 18px; max-width: 54ch; }
  .about p.soft { color: var(--muted); }
  .currently { margin: 26px 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .currently li { display: flex; align-items: baseline; gap: 12px; font-size: 15.5px; color: var(--muted); }
  .currently .lab { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent);
    background: var(--accent-soft); padding: 3px 8px; border-radius: 5px; flex: none; }
  .currently b { color: var(--text); font-weight: 600; }

  .contact { margin-top: 44px; padding-top: 34px; border-top: 1px solid var(--border); }
  .contact .eyebrow { margin-bottom: 12px; }
  a.mail { color: var(--accent); text-decoration: none; font-size: 17px; font-weight: 600; border-bottom: 1px solid var(--accent-soft); }
  a.mail:hover { border-bottom-color: var(--accent); }
  .socials { display: flex; gap: 12px; margin-top: 22px; }
  .socials a { width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--border); color: var(--muted);
    display: grid; place-items: center; transition: all .15s ease; }
  .socials a:hover { color: #fff; background: var(--accent); border-color: var(--accent); transform: translateY(-2px); }
  .socials svg { width: 19px; height: 19px; }

  .portrait { position: relative; border-radius: 16px; overflow: hidden; background: var(--surface);
    border: 1px solid var(--border); aspect-ratio: 4/5; box-shadow: 0 20px 40px -30px rgba(23,19,15,0.5); }
  .portrait img { width: 100%; height: 100%; object-fit: cover; display: block; }

  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr; }
    .portrait { max-width: 360px; }
  }
</style>
